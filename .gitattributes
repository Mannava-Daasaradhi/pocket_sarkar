# Prevent binary corruption on Windows (no CRLF conversion for binary files)
*.png    binary
*.jpg    binary
*.jpeg   binary
*.webp   binary
*.gif    binary
*.ico    binary
*.jar    binary
*.db     binary
*.tflite binary
*.bin    binary
*.task   binary

# Force LF for all text source files
*.kt         text eol=lf
*.kts        text eol=lf
*.xml        text eol=lf
*.json       text eol=lf
*.py         text eol=lf
*.md         text eol=lf
*.txt        text eol=lf
*.toml       text eol=lf
*.properties text eol=lf
*.pro        text eol=lf
gradlew      text eol=lf
