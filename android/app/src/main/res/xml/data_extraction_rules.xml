<?xml version="1.0" encoding="utf-8"?>
<!--
    Privacy-first: no user data is transferred on device backup.
    Scheme DB and model weights are excluded — both are re-downloadable.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pocket_sarkar.db" />
        <exclude domain="file" path="models/" />
        <exclude domain="external" path="models/" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pocket_sarkar.db" />
        <exclude domain="file" path="models/" />
    </device-transfer>
</data-extraction-rules>
